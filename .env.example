# ─────────────────────────────────────────────────────────────
# NutriCheck — Environment Variables Template
# Copy this file to `.env` and fill in your real credentials.
# The `.env` file should NEVER be committed to git.
# ─────────────────────────────────────────────────────────────

# Flask Secret Key (generate a random string — keep it secret!)
SECRET_KEY=your-super-secret-flask-key-change-this

# ── Google OAuth 2.0 Credentials ──────────────────────────────
# Get these from: https://console.cloud.google.com
# Create a project → Credentials → OAuth 2.0 Client ID
# Set Authorized redirect URI to: http://localhost:5000/auth/google/callback
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── Google Gemini API Key ──────────────────────────────────────
# Get your free key from: https://aistudio.google.com
GEMINI_API_KEY=your-gemini-api-key
